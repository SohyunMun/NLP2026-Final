{
  "method": "DPO + reference-free reranking",
  "device": "cuda",
  "args": {
    "sft_checkpoint": "sonnet_project/experiments/sixway_ablation/dapt_sft_intermediate/best_10-1e-05-sonnet.pt",
    "dpo_checkpoint": "sonnet_project/experiments/sixway_ablation/dapt_sft_lora_dpo_best_chrf/best_chrf_lora_dpo_form_rhyme.pt",
    "dev_prompt_path": "sonnet_project/data/strict_497/dev_prompts_12.txt",
    "test_prompt_path": "sonnet_project/data/strict_497/test_prompts_12.txt",
    "output_dir": "sonnet_project/experiments/dpo_reranking",
    "seed": 11711,
    "seed_stride": 100,
    "use_gpu": true,
    "lora_r": 8,
    "lora_alpha": 16,
    "lora_dropout": 0.05,
    "num_candidates": 6,
    "temperature": 0.9,
    "top_p": 0.92,
    "top_k": 60,
    "num_beams": 4,
    "decoding_strategy": "top_p",
    "decoding_strategies": "top_p,top_k",
    "repetition_penalty": 1.08,
    "no_repeat_ngram_size": 3,
    "max_generation_tokens": 120,
    "target_lines": 14,
    "prompt_lines": 3,
    "score_part": "full",
    "mattr_window": 50,
    "sonnet_form_threshold": 0.7,
    "sonnet_line_length_threshold": 0.5,
    "sonnet_rhyme_threshold": 0.25,
    "sonnet_couplet_threshold": 0.25,
    "poemetric_weight": 0.55,
    "form_weight": 0.15,
    "rhyme_weight": 0.2,
    "couplet_weight": 0.1,
    "theme_weight": 0.1,
    "lexical_weight": 0.05,
    "non_repetition_weight": 0.05,
    "mbr_weight": 0.05,
    "model_weight": 0.0,
    "sonnet_pass_bonus": 0.1
  },
  "splits": [
    {
      "split": "dev",
      "prompt_path": "sonnet_project/data/strict_497/dev_prompts_12.txt",
      "prediction_path": "sonnet_project/experiments/dpo_reranking/predictions/dev_reranked.txt",
      "candidates_jsonl": "sonnet_project/experiments/dpo_reranking/candidates/dev_candidates.jsonl",
      "candidate_metrics_csv": "sonnet_project/experiments/dpo_reranking/candidate_metrics/dev_candidates.csv",
      "num_prompts": 12,
      "num_candidates_requested": 6,
      "avg_unique_candidates": 6.0
    },
    {
      "split": "test",
      "prompt_path": "sonnet_project/data/strict_497/test_prompts_12.txt",
      "prediction_path": "sonnet_project/experiments/dpo_reranking/predictions/test_reranked.txt",
      "candidates_jsonl": "sonnet_project/experiments/dpo_reranking/candidates/test_candidates.jsonl",
      "candidate_metrics_csv": "sonnet_project/experiments/dpo_reranking/candidate_metrics/test_candidates.csv",
      "num_prompts": 12,
      "num_candidates_requested": 6,
      "avg_unique_candidates": 6.0
    }
  ]
}
